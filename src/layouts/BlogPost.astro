---
import { Image } from 'astro:assets';
import type { CollectionEntry } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import FormattedDate from '../components/FormattedDate.astro';
import Header from '../components/Header.astro';

type Props = CollectionEntry<'blog'>['data'] & {
	hasBilingual?: boolean;
};

const { title, title_ko, description, description_ko, pubDate, updatedDate, heroImage, tags, hasBilingual } = Astro.props;
---

<html lang="en">
	<head>
		<BaseHead title={title} description={description} />
	</head>

	<body class="min-h-screen flex flex-col">
		<Header />
		<main class="flex-1">
			<article>
				<!-- Hero Image -->
				{heroImage && (
					<div class="relative w-full max-w-4xl mx-auto px-6 pt-8">
						<div class="retro-window">
							<div class="retro-titlebar">
								<div class="retro-titlebar-dots">
									<span></span><span></span><span></span>
								</div>
								hero_image.png
							</div>
							<Image
								width={1020}
								height={510}
								src={heroImage}
								alt=""
								class="w-full h-auto object-cover"
							/>
						</div>
					</div>
				)}

				<!-- Content -->
				<div class="mx-auto max-w-3xl px-6 py-10">
					<!-- Title Block -->
					<header class="mb-10">
						<div class="retro-window">
							<div class="retro-titlebar">
								<div class="retro-titlebar-dots">
									<span></span><span></span><span></span>
								</div>
								article_info.dat
							</div>
							<div class="p-6 text-center">
								<div class="mb-4 flex items-center justify-center gap-4">
									<FormattedDate date={pubDate} />
									{updatedDate && (
										<span class="text-text-secondary" style="font-family: var(--font-mono); font-size: 0.85rem;">
											· Updated: <FormattedDate date={updatedDate} />
										</span>
									)}
								</div>

								<!-- Bilingual Title -->
								{hasBilingual && title_ko ? (
									<>
										<h1 data-lang-content="en" class="neon-green" style="font-family: var(--font-pixel); font-size: clamp(0.7rem, 2.5vw, 1.1rem); text-transform: uppercase; line-height: 2.2;">
											{title}
										</h1>
										<h1 data-lang-content="ko" class="neon-green" style="font-family: var(--font-pixel); font-size: clamp(0.7rem, 2.5vw, 1.1rem); text-transform: uppercase; line-height: 2.2; display: none;">
											{title_ko}
										</h1>
									</>
								) : (
									<h1 class="neon-green" style="font-family: var(--font-pixel); font-size: clamp(0.7rem, 2.5vw, 1.1rem); text-transform: uppercase; line-height: 2.2;">
										{title}
									</h1>
								)}

								<!-- Bilingual Description -->
								{hasBilingual && description_ko ? (
									<>
										<p data-lang-content="en" class="mt-4 text-text-secondary" style="font-family: var(--font-mono); font-size: 1.05rem;">
											&gt; {description}
										</p>
										<p data-lang-content="ko" class="mt-4 text-text-secondary" style="font-family: var(--font-mono); font-size: 1.05rem; display: none;">
											&gt; {description_ko}
										</p>
									</>
								) : description && (
									<p class="mt-4 text-text-secondary" style="font-family: var(--font-mono); font-size: 1.05rem;">
										&gt; {description}
									</p>
								)}

								{tags && tags.length > 0 && (
									<div class="mt-4 flex items-center justify-center gap-2 flex-wrap">
										{tags.map((tag: string) => (
											<a
												href={`/tags/${tag}/`}
												class="text-[0.4rem] px-2 py-1 border border-neon-yellow text-neon-yellow hover:bg-neon-yellow/10 transition-colors duration-150"
												style="font-family: var(--font-pixel); text-transform: uppercase; letter-spacing: 1px;"
											>
												#{tag}
											</a>
										))}
									</div>
								)}
							</div>
						</div>
						<div class="mt-6 text-center text-text-secondary" style="font-family: var(--font-mono); font-size: 0.9rem;">
							════════════════════════════════════
						</div>
					</header>

					<!-- Article Body -->
					<div class="prose">
						<slot />
					</div>

					<!-- End of Article -->
					<div class="mt-12 text-center">
						<p class="text-text-secondary" style="font-family: var(--font-mono); font-size: 0.9rem;">
							════════════════════════════════════
						</p>
						<p class="mt-4 neon-green" style="font-family: var(--font-pixel); font-size: 0.5rem; text-transform: uppercase;">
							— End of File —
						</p>
						<a href="/blog" class="pixel-btn mt-6 inline-block">
							← Back to Blog
						</a>
					</div>
				</div>
			</article>
		</main>
		<Footer />
	</body>
</html>

<script>
	/**
	 * 마크다운 본문의 <!-- lang:en --> / <!-- lang:ko --> 구분자를 감지하여
	 * 해당 섹션을 data-lang-content 속성의 div로 감싸는 클라이언트 스크립트.
	 */
	function wrapLangSections() {
		const prose = document.querySelector('.prose');
		if (!prose) return;

		const html = prose.innerHTML;

		// 구분자가 없으면 처리하지 않음
		if (!html.includes('<!-- lang:en -->') && !html.includes('<!-- lang:ko -->')) return;

		// 구분자 기준으로 언어 섹션 분리
		const parts = html.split(/<!--\s*lang:(en|ko)\s*-->/);

		let result = '';
		let currentLang = 'en'; // 구분자 이전의 기본 언어

		for (let i = 0; i < parts.length; i++) {
			if (parts[i] === 'en' || parts[i] === 'ko') {
				currentLang = parts[i];
				continue;
			}

			const content = parts[i].trim();
			if (!content) continue;

			if (i === 0 && !html.trimStart().startsWith('<!-- lang:')) {
				// 구분자 이전의 콘텐츠는 항상 표시
				result += content;
			} else {
				result += `<div data-lang-content="${currentLang}">${content}</div>`;
			}
		}

		prose.innerHTML = result;

		// 현재 저장된 언어로 표시 상태 재적용
		const saved = localStorage.getItem('blog-lang') || 'en';
		document.querySelectorAll('[data-lang-content]').forEach((el) => {
			const htmlEl = el as HTMLElement;
			if (htmlEl.dataset.langContent === saved) {
				htmlEl.style.display = '';
			} else {
				htmlEl.style.display = 'none';
			}
		});
	}

	wrapLangSections();
	document.addEventListener('astro:after-swap', wrapLangSections);
</script>
