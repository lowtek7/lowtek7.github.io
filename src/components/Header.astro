---
import { SITE_TITLE } from '../consts';

const currentPath = Astro.url.pathname;

const navLinks = [
	{ href: '/', label: 'Home', icon: '🏠' },
	{ href: '/blog', label: 'Blog', icon: '📝' },
	{ href: '/tags', label: 'Tags', icon: '🏷️' },
	{ href: '/about', label: 'About', icon: '👾' },
];
---

<header class="fixed top-0 left-0 right-0 z-50 border-b-2 border-border-default bg-bg-primary/95">
	<nav class="mx-auto flex max-w-5xl items-center justify-between px-6 py-3">
		<!-- Logo -->
		<a href="/" class="group flex items-center gap-3" id="site-logo">
			<span class="text-lg neon-green">▶</span>
			<span class="font-pixel text-[0.65rem] uppercase tracking-wider text-neon-green transition-all duration-200 group-hover:tracking-widest"
				style="font-family: var(--font-pixel); text-shadow: 0 0 10px rgba(57,255,20,0.4);">
				{SITE_TITLE}
			</span>
		</a>

		<!-- Desktop Nav -->
		<div class="hidden items-center gap-1 md:flex" id="desktop-nav">
			{navLinks.map(({ href, label, icon }) => {
				const isActive = currentPath === href || (href !== '/' && currentPath.startsWith(href));
				return (
					<a
						href={href}
						class:list={[
							'flex items-center gap-2 px-4 py-2 text-sm transition-all duration-150 border',
							isActive
								? 'border-neon-green bg-neon-green/10 text-neon-green'
								: 'border-transparent text-text-secondary hover:text-neon-green hover:border-border-default',
						]}
						style="font-family: var(--font-pixel); font-size: 0.55rem; text-transform: uppercase; letter-spacing: 1px;"
					>
						<span>{icon}</span>
						{label}
					</a>
				);
			})}
		</div>

		<!-- Status Bar -->
		<div class="hidden items-center gap-4 md:flex" id="status-bar">
			<span class="text-[0.5rem] text-text-secondary" style="font-family: var(--font-pixel);">
				LV.99
			</span>
			<a
				href="https://github.com/lowtek7"
				target="_blank"
				rel="noopener noreferrer"
				class="text-text-secondary transition-colors duration-200 hover:text-neon-green"
				aria-label="GitHub"
			>
				<svg viewBox="0 0 16 16" width="18" height="18" fill="currentColor">
					<path d="M8 0C3.58 0 0 3.58 0 8c0 3.54 2.29 6.53 5.47 7.59.4.07.55-.17.55-.38 0-.19-.01-.82-.01-1.49-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13-.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66.07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82.64-.18 1.32-.27 2-.27.68 0 1.36.09 2 .27 1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48 0 1.07-.01 1.93-.01 2.2 0 .21.15.46.55.38A8.012 8.012 0 0 0 16 8c0-4.42-3.58-8-8-8z"/>
				</svg>
			</a>
		</div>

		<!-- Mobile Menu Button -->
		<button
			id="mobile-menu-btn"
			class="flex items-center justify-center p-2 text-neon-green border border-border-default md:hidden hover:bg-neon-green/10"
			aria-label="Toggle menu"
			style="font-family: var(--font-pixel); font-size: 0.6rem;"
		>
			<span id="menu-text">MENU</span>
			<span id="close-text" class="hidden">EXIT</span>
		</button>
	</nav>

	<!-- Mobile Menu -->
	<div id="mobile-menu" class="hidden border-t-2 border-border-default bg-bg-primary md:hidden">
		<div class="mx-auto max-w-5xl px-6 py-4 space-y-1">
			{navLinks.map(({ href, label, icon }) => {
				const isActive = currentPath === href || (href !== '/' && currentPath.startsWith(href));
				return (
					<a
						href={href}
						class:list={[
							'flex items-center gap-3 px-4 py-3 text-sm border transition-all duration-150',
							isActive
								? 'border-neon-green bg-neon-green/10 text-neon-green'
								: 'border-transparent text-text-secondary hover:text-neon-green hover:border-border-default',
						]}
						style="font-family: var(--font-pixel); font-size: 0.55rem; text-transform: uppercase; letter-spacing: 1px;"
					>
						<span>{icon}</span>
						{label}
					</a>
				);
			})}
		</div>
	</div>
</header>

<!-- Spacer for fixed header -->
<div class="h-14"></div>

<script>
	const menuBtn = document.getElementById('mobile-menu-btn');
	const mobileMenu = document.getElementById('mobile-menu');
	const menuText = document.getElementById('menu-text');
	const closeText = document.getElementById('close-text');

	menuBtn?.addEventListener('click', () => {
		mobileMenu?.classList.toggle('hidden');
		menuText?.classList.toggle('hidden');
		closeText?.classList.toggle('hidden');
	});
</script>
