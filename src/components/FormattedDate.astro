---
interface Props {
	date: Date;
}

const { date } = Astro.props;
---

<time datetime={date.toISOString()} class="text-text-secondary" style="font-family: var(--font-mono); font-size: 0.9rem;">
	{date.toLocaleDateString('en-US', {
		year: 'numeric',
		month: 'short',
		day: 'numeric',
	})}
</time>
