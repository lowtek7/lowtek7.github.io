---
import { SITE_TITLE } from '../consts';
const today = new Date();
---

<footer class="border-t-2 border-border-default bg-bg-secondary/80">
	<div class="mx-auto max-w-5xl px-6 py-10">
		<div class="flex flex-col items-center gap-8 md:flex-row md:justify-between">
			<!-- Brand -->
			<div class="text-center md:text-left">
				<a href="/" class="neon-green" style="font-family: var(--font-pixel); font-size: 0.6rem; text-transform: uppercase;">
					▶ {SITE_TITLE}
				</a>
				<p class="mt-2 text-sm text-text-secondary" style="font-family: var(--font-mono); font-size: 1.1rem;">
					// Exploring ideas, code, and creativity
				</p>
			</div>

			<!-- Links -->
			<div class="flex items-center gap-6 text-text-secondary" style="font-family: var(--font-pixel); font-size: 0.45rem; text-transform: uppercase; letter-spacing: 1px;">
				<a href="/" class="hover:text-neon-green transition-colors duration-150">[Home]</a>
				<a href="/blog" class="hover:text-neon-pink transition-colors duration-150">[Blog]</a>
				<a href="/about" class="hover:text-neon-cyan transition-colors duration-150">[About]</a>
				<a
					href="/rss.xml"
					class="hover:text-neon-yellow transition-colors duration-150"
					aria-label="RSS Feed"
				>
					[RSS]
				</a>
			</div>
		</div>

		<!-- ASCII Art Divider + Copyright -->
		<div class="mt-8 border-t-2 border-dashed border-border-default pt-6 text-center">
			<p class="text-text-secondary" style="font-family: var(--font-mono); font-size: 0.9rem;">
				═══════════════════════════════════════
			</p>
			<p class="mt-2 text-text-secondary" style="font-family: var(--font-pixel); font-size: 0.4rem; text-transform: uppercase; letter-spacing: 2px;">
				&copy; {today.getFullYear()} {SITE_TITLE} &bull; All rights reserved
			</p>
			<p class="mt-2 text-text-secondary" style="font-family: var(--font-mono); font-size: 0.9rem;">
				PRESS START TO CONTINUE...
			</p>
		</div>
	</div>
</footer>
