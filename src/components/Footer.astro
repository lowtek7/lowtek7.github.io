---
import { SITE_TITLE } from '../consts';
const today = new Date();
---

<footer class="border-t border-border-subtle bg-bg-secondary/50">
	<div class="mx-auto max-w-5xl px-6 py-12">
		<div class="flex flex-col items-center gap-6 md:flex-row md:justify-between">
			<!-- Brand -->
			<div class="text-center md:text-left">
				<a href="/" class="text-lg font-bold bg-gradient-to-r from-accent to-accent-light bg-clip-text text-transparent">
					{SITE_TITLE}
				</a>
				<p class="mt-1 text-sm text-text-secondary">
					Exploring ideas, code, and creativity.
				</p>
			</div>

			<!-- Links -->
			<div class="flex items-center gap-6 text-sm text-text-secondary">
				<a href="/" class="transition-colors duration-200 hover:text-text-primary">Home</a>
				<a href="/blog" class="transition-colors duration-200 hover:text-text-primary">Blog</a>
				<a href="/about" class="transition-colors duration-200 hover:text-text-primary">About</a>
				<a
					href="/rss.xml"
					class="transition-colors duration-200 hover:text-accent"
					aria-label="RSS Feed"
				>
					<svg viewBox="0 0 24 24" width="18" height="18" fill="currentColor">
						<path d="M6.18 15.64a2.18 2.18 0 0 1 2.18 2.18C8.36 19 7.38 20 6.18 20C5 20 4 19 4 17.82a2.18 2.18 0 0 1 2.18-2.18M4 4.44A15.56 15.56 0 0 1 19.56 20h-2.83A12.73 12.73 0 0 0 4 7.27V4.44m0 5.66a9.9 9.9 0 0 1 9.9 9.9h-2.83A7.07 7.07 0 0 0 4 12.93V10.1z"/>
					</svg>
				</a>
			</div>
		</div>

		<!-- Copyright -->
		<div class="mt-8 border-t border-border-subtle pt-6 text-center text-xs text-text-secondary">
			<p>&copy; {today.getFullYear()} {SITE_TITLE}. All rights reserved.</p>
		</div>
	</div>
</footer>
