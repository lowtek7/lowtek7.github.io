---
import { Image } from 'astro:assets';
import { getCollection } from 'astro:content';
import BaseHead from '../../components/BaseHead.astro';
import Footer from '../../components/Footer.astro';
import FormattedDate from '../../components/FormattedDate.astro';
import Header from '../../components/Header.astro';
import { SITE_TITLE } from '../../consts';

const posts = (await getCollection('blog')).sort(
	(a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={`Blog — ${SITE_TITLE}`} description="All blog posts" />
	</head>
	<body class="min-h-screen flex flex-col">
		<Header />
		<main class="flex-1">
			<div class="mx-auto max-w-5xl px-6 py-12">
				<!-- Page Header -->
				<div class="retro-window mb-10">
					<div class="retro-titlebar">
						<div class="retro-titlebar-dots">
							<span></span><span></span><span></span>
						</div>
						blog_archive.dat
					</div>
					<div class="p-6">
						<h1 style="font-family: var(--font-pixel); font-size: 1rem; color: var(--color-neon-cyan); text-transform: uppercase;">
							📂 Blog Archive
						</h1>
						<p class="mt-3 text-text-secondary" style="font-family: var(--font-mono); font-size: 1rem;">
							> Listing all entries... [{posts.length} files found]
						</p>
						<div class="mt-3 h-0.5 w-24 bg-neon-cyan"></div>
					</div>
				</div>

				<!-- Posts List -->
				<div class="space-y-4">
					{posts.map((post, index) => (
						<a
							href={`/blog/${post.id}/`}
							class="group flex flex-col overflow-hidden retro-window transition-all duration-200 hover:border-neon-green sm:flex-row"
						>
							<div class="retro-titlebar sm:hidden">
								<div class="retro-titlebar-dots">
									<span></span><span></span><span></span>
								</div>
								entry_{String(index + 1).padStart(3, '0')}.md
							</div>
							{post.data.heroImage && (
								<div class="overflow-hidden sm:w-56 sm:flex-shrink-0 border-b-2 sm:border-b-0 sm:border-r-2 border-border-default">
									<Image
										width={320}
										height={180}
										src={post.data.heroImage}
										alt=""
										class="h-40 w-full object-cover transition-all duration-300 group-hover:brightness-125 sm:h-full"
									/>
								</div>
							)}
							<div class="flex flex-col justify-center p-5 flex-1">
								<div class="flex items-center gap-3 mb-2">
									<span class="neon-green" style="font-family: var(--font-pixel); font-size: 0.4rem;">
										[{String(index + 1).padStart(2, '0')}]
									</span>
									<FormattedDate date={post.data.pubDate} />
								</div>
								<h2 class="text-text-primary transition-colors duration-200 group-hover:text-neon-green" style="font-family: var(--font-pixel); font-size: 0.6rem; text-transform: uppercase; line-height: 2;">
									{post.data.title}
								</h2>
								<p class="mt-2 text-text-secondary" style="font-family: var(--font-mono); font-size: 0.95rem;">
									{post.data.description}
								</p>
								{post.data.tags && post.data.tags.length > 0 && (
									<div class="mt-2 flex flex-wrap gap-1.5">
										{post.data.tags.map((tag: string) => (
											<span
												class="text-[0.35rem] px-1.5 py-0.5 border border-neon-yellow/50 text-neon-yellow/70"
												style="font-family: var(--font-pixel); text-transform: uppercase; letter-spacing: 1px;"
											>
												#{tag}
											</span>
										))}
									</div>
								)}
								<span class="mt-3 text-neon-green opacity-0 transition-opacity duration-200 group-hover:opacity-100" style="font-family: var(--font-pixel); font-size: 0.4rem; text-transform: uppercase;">
									▶ Read more...
								</span>
							</div>
						</a>
					))}
				</div>
			</div>
		</main>
		<Footer />
	</body>
</html>
