---
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import { SITE_TITLE } from '../consts';
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={`About — ${SITE_TITLE}`} description="About Amber World" />
	</head>
	<body class="min-h-screen flex flex-col">
		<Header />
		<main class="flex-1">
			<div class="mx-auto max-w-3xl px-6 py-16">
				<!-- Page Header -->
				<div class="mb-12 text-center">
					<h1 class="text-3xl font-bold text-text-primary md:text-4xl">About</h1>
					<div class="mt-4 h-px w-20 mx-auto bg-gradient-to-r from-transparent via-accent to-transparent"></div>
				</div>

				<!-- Profile Section -->
				<div class="mb-12 flex flex-col items-center gap-6 rounded-2xl border border-border-subtle bg-bg-card p-8 md:flex-row md:items-start">
					<!-- Avatar Placeholder -->
					<div class="flex h-24 w-24 flex-shrink-0 items-center justify-center rounded-full bg-gradient-to-br from-accent to-amber-300 text-3xl font-bold text-bg-primary">
						A
					</div>
					<div class="text-center md:text-left">
						<h2 class="text-xl font-bold text-text-primary">Amber</h2>
						<p class="mt-1 text-sm text-accent">Developer & Creator</p>
						<p class="mt-3 text-text-secondary leading-relaxed">
							Welcome to Amber World! This is my personal space where I share thoughts on development, 
							technology, and the creative process. I believe in building things that make a difference.
						</p>
						<div class="mt-4 flex items-center justify-center gap-3 md:justify-start">
							<a
								href="https://github.com/lowtek7"
								target="_blank"
								rel="noopener noreferrer"
								class="inline-flex items-center gap-2 rounded-lg border border-border-default bg-bg-tertiary px-4 py-2 text-sm text-text-secondary transition-all duration-200 hover:border-accent/30 hover:text-text-primary"
							>
								<svg viewBox="0 0 16 16" width="16" height="16" fill="currentColor">
									<path d="M8 0C3.58 0 0 3.58 0 8c0 3.54 2.29 6.53 5.47 7.59.4.07.55-.17.55-.38 0-.19-.01-.82-.01-1.49-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13-.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66.07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82.64-.18 1.32-.27 2-.27.68 0 1.36.09 2 .27 1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48 0 1.07-.01 1.93-.01 2.2 0 .21.15.46.55.38A8.012 8.012 0 0 0 16 8c0-4.42-3.58-8-8-8z"/>
								</svg>
								GitHub
							</a>
						</div>
					</div>
				</div>

				<!-- Content -->
				<div class="prose">
					<h2>What is Amber World?</h2>
					<p>
						Amber World is a space dedicated to exploring the intersection of technology and creativity. 
						Here you'll find articles about software development, programming insights, and reflections 
						on the craft of building digital products.
					</p>

					<h2>What I Write About</h2>
					<ul>
						<li><strong>Software Development</strong> — Deep dives into code, architecture, and best practices</li>
						<li><strong>Game Development</strong> — Exploring game design patterns and engine development</li>
						<li><strong>Technology</strong> — Thoughts on tools, frameworks, and the evolving tech landscape</li>
						<li><strong>Creative Process</strong> — How I approach problem-solving and project building</li>
					</ul>

					<h2>Get in Touch</h2>
					<p>
						Feel free to reach out through <a href="https://github.com/lowtek7">GitHub</a>. 
						I'm always happy to connect with fellow developers and creators.
					</p>
				</div>
			</div>
		</main>
		<Footer />
	</body>
</html>
